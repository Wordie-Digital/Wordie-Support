# ─────────────────────────────────────────────
# Wordie Health Dashboard — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://wordie:localdev@localhost:5432/wordie_health
POSTGRES_PASSWORD=localdev

# Redis (optional for local dev)
REDIS_URL=redis://localhost:6379

# WP Engine API
# Generate at: https://my.wpengine.com/api_access
WPENGINE_USER=your_wpengine_username
WPENGINE_PASS=your_wpengine_password

# GitHub (read:repo, security_events scopes required)
GITHUB_TOKEN=ghp_your_token_here

# Google PageSpeed Insights
# Generate at: https://console.cloud.google.com/apis/credentials
PAGESPEED_API_KEY=AIza_your_key_here

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3031
DASHBOARD_URL=http://localhost:3030

# Hosting
PORT=3031
NODE_ENV=development
