{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "barnardos-report-html",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "health-dashboard", "-l", "3031"],
      "port": 3031
    },
    {
      "name": "health-dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "health-dashboard/apps/dashboard",
      "port": 3030
    },
    {
      "name": "Node API (dev watch)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server/index.js"],
      "port": 3000
    },
    {
      "name": "Node API (production)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js"],
      "port": 3000
    },
    {
      "name": "Static frontend (index.html)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-s", ".", "-l", "5173"],
      "port": 5173
    }
  ]
}
